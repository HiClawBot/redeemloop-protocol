{
  "name": "@redeemloop/widget",
  "private": true,
  "version": "0.9.2",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "pretest": "pnpm --filter @redeemloop/core build && pnpm --filter @redeemloop/adapters build && pnpm --filter @redeemloop/sdk build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@redeemloop/adapters": "workspace:*",
    "@redeemloop/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
